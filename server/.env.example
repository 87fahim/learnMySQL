# Copy to `.env` in this folder (`server/.env`).
# NEVER commit `.env`; it holds secrets.

# API port (frontend dev proxy expects the same unless you override VITE_API_PROXY_TARGET).
PORT=4000

# MySQL connection — change DB_PASSWORD and optionally DB_USER / DB_NAME to match your setup.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me

# Initial database shown in explorers — any database your user can read will work.
# Common choices: a sample DB you imported, or `mysql` (system schema) for quick smoke tests.
DB_NAME=mysql

# Optional: allow browser origin (defaults are fine for local dev with Vite proxy).
# CORS_ORIGIN=http://localhost:5173

# Optional: safety limits (defaults match server env schema if omitted after code load).
# QUERY_TIMEOUT_MS=30000
# MAX_ROWS=5000
