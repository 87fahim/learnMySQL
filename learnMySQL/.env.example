# Omit VITE_API_BASE_URL in dev: the app calls `/api/...`, and Vite proxies to the backend.
# VITE_API_BASE_URL=http://localhost:4000

# Optional: frontend-only demo row (leave unset or false to use MySQL via the API)
# VITE_USE_MOCK_API=true

# Backend URL for `/api` proxy during `npm run dev` → must match `PORT` in `server/.env`
# VITE_API_PROXY_TARGET=http://localhost:4000

# MySQL credentials belong in server/.env (see server/.env.example), never here.
